VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_STRICT_ENV=false
VITE_MAGIC_LINK_REDIRECT_TO=zero1://auth/callback
DESKTOP_AUTO_UPDATE_ENABLED=true
DESKTOP_UPDATE_CHANNEL=latest
DESKTOP_ALLOW_PLAINTEXT_SESSION_FALLBACK=false
# Optional override for desktop userData/cache directory.
# Example (Windows): DESKTOP_USER_DATA_DIR=C:\\Users\\you\\AppData\\Roaming\\zero1-desktop-dev
DESKTOP_USER_DATA_DIR=
# Optional: point Electron window at full web UI (used for local full-app shell).
# Example: DESKTOP_WEB_APP_URL=http://localhost:5173
DESKTOP_WEB_APP_URL=
# Optional if not using GitHub release provider metadata:
# DESKTOP_UPDATE_FEED_URL=https://your-update-host.example.com
