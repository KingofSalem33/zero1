    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zero1.mobile",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.zero1.mobile",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3389b803-88f4-4fec-aebb-7eefa88f066a"
      }
    },
    "plugins": ["expo-dev-client", "expo-web-browser", "@sentry/react-native"],
    "owner": "cmoney612s-organization",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3389b803-88f4-4fec-aebb-7eefa88f066a"
    }
  }
