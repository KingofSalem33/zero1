PORT=3001
NODE_ENV=development
STRICT_ENV=false

# OpenAI credentials
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL_NAME=gpt-5-mini

# Model Selection Strategy
# FAST: backend/internal operations (speed)
# SMART: user-facing text generation (quality)
OPENAI_FAST_MODEL=gpt-5-nano
OPENAI_SMART_MODEL=gpt-5-mini

# Embeddings provider/model (used by map building, semantic retrieval, suggested topics)
# Keep embeddings on OpenAI for stability.
EMBEDDING_MODEL_NAME=text-embedding-3-small

# Legacy fallback (optional - only needed if you want to override both tiers)
# OPENAI_MODEL_NAME=gpt-4o-mini

# Supabase Configuration
SUPABASE_URL=https://ciuxquemfnbruvvzbfth.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImNpdXhxdWVtZm5icnV2dnpiZnRoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTkxOTA2MDcsImV4cCI6MjA3NDc2NjYwN30.LePFhqBk-aVFajEF6yQAyXsZyOaBkF-7PMpaHTmgMbY
SUPABASE_SERVICE_KEY=your_service_key_here

# Comma-separated CORS allowlist for browser clients.
# Production should include your web domain(s). Local desktop loopback
# origins (`localhost` + `127.0.0.1`) and Electron (`Origin: null`)
# are merged automatically at runtime.
CORS_ALLOWED_ORIGINS=https://your-web-domain.com

# Sentry Configuration
# Get your DSN from: https://sentry.io/settings/[your-org]/projects/[your-project]/keys/
SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/your-project-id
